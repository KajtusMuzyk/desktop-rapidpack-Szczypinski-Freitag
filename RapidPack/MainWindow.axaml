<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="900"
        x:Class="RapidPack.MainWindow"
        Title="RapidPack"
        Background="#E0E0E0">
     <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        
        <StackPanel Spacing="10">
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Border Width="90" Height="90" 
                        Background="NavajoWhite" 
                        BorderBrush="Azure" 
                        BorderThickness="3" 
                        CornerRadius="15"
                        BoxShadow="0 4 10 0 #40000000"> <Image Source="Assets/ikona.png" Margin="5"/>
                </Border>
                
                <TextBlock Text="RapidPack"
                           FontSize="40"
                           FontWeight="Black"
                           FontStyle="Oblique"
                           Foreground="#2C3E50"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </StackPanel>

            <Border Width="600" 
                    Background="NavajoWhite" 
                    BorderBrush="Azure" 
                    BorderThickness="4" 
                    CornerRadius="30"
                    BoxShadow="0 10 20 0 #30000000">
                 <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto" Margin="40">
                    
                    <TextBlock Grid.Row="0" 
                               Text="KALKULATOR CENY" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               LetterSpacing="2"
                               Margin="0,0,0,30" 
                               HorizontalAlignment="Center" 
                               Foreground="#5D4037"/>

                    <StackPanel Grid.Row="1" Margin="0,10">
                        <TextBlock Text="Waga (kg)" FontWeight="Medium" Margin="0,0,0,5"/>
                        <NumericUpDown x:Name="WeightInput" Minimum="0" Maximum="100" Increment="1" Value="0" Background="White"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,10">
                        <TextBlock Text="Typ przesyłki" FontWeight="Medium" Margin="0,0,0,5"/>
                        <ComboBox x:Name="TypeInput" HorizontalAlignment="Stretch" SelectedIndex="0" Background="White">
                            <ComboBoxItem Content="Standardowa"/>
                            <ComboBoxItem Content="Ostrożnie (szkło)"/>
                            <ComboBoxItem Content="Paleta"/>
                        </ComboBox>
                    </StackPanel>

                    <Grid Grid.Row="3" ColumnDefinitions="*, *, *" Margin="0,20">
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Wysokość (cm)" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="HeightInput" Text="0" Background="White"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <TextBlock Text="Szerokość (cm)" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="WidthInput" Text="0" Background="White"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Głębokość (cm)" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="DepthInput" Text="0" Background="White"/>
                        </StackPanel>
                    </Grid>
                    
                    <CheckBox Grid.Row="4" x:Name="ExpressInput" Content="Przesyłka Express (+15 zł)" Margin="0,10"/>
                    
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
